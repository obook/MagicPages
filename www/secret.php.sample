/*
 * secret.php n'est PAS versionné (il contient les vrais mots de passe).
 * Pour installer le site : copier ce modèle en "secret.php", puis remplacer
 * les valeurs ci-dessous.
 *
 * La connexion se fait par mot de passe seul, sans identifiant : n'importe
 * quel mot de passe de cette liste ouvre l'accès. On peut donc en distribuer
 * plusieurs (un par personne) et en révoquer un sans gêner les autres.
 *
 * Ce fichier RETOURNE un tableau : un accès direct par l'URL n'affiche
 * rien (page blanche), donc les mots de passe ne sont jamais exposés.
 *
 * Les mots de passe sont stockés en clair.
 *
 * En plus de cette liste, un code du jour est toujours accepté : le jour
 * sur 2 chiffres suivi du mois sur 2 chiffres (par exemple "0206" le 2 juin).
 */
return [
    'changez-moi',
];
